  },
  "scripts": {
    "generate:posts": "node scripts/generate-post-modules.mjs",
    "dev": "pnpm generate:posts && next dev",
    "dev:watch": "next-remote-watch ./posts",
    "build": "pnpm generate:posts && next build",
    "build_static": "pnpm generate:posts && ENV=static next build",
    "start": "next start",
    "export": "pnpm generate:posts && ENV=static next build",
    "lint": "eslint .",
    "test": "pnpm generate:posts && jest"
  },
  "dependencies": {
