    "@tailwindcss/typography": "^0.5.9",
    "classnames": "^2.3.2",
    "gray-matter": "^4.0.3",
    "next": "16.2.1",
    "next-remote-watch": "2.0.0",
    "prismjs": "^1.29.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remark-mdx-images": "^3.0.0",
    "tailwindcss": "^3.3.3",
    "typescript": "5.1.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
